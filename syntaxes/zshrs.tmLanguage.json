    "builtins": {
      "match": "\\b(?:comparguments|pcre_compile|compdescribe|zregexparse|zparseopts|unfunction|pcre_study|pcre_match|compvalues|compgroups|zlistattr|zgdbmpath|functions|compquote|compfiles|zsetattr|zmodload|zgetattr|zf_rmdir|zf_mkdir|zf_chown|zf_chmod|zf_chgrp|zdelattr|zcompile|unsetopt|syswrite|syserror|strftime|patdebug|hashinfo|comptags|compcall|autoload|zsystem|zsocket|zselect|zformat|zf_sync|zcurses|unlimit|unalias|sysseek|sysread|sysopen|suspend|private|nameref|history|getopts|example|emulate|disable|comptry|compset|compctl|compadd|command|builtin|bindkey|zuntie|zstyle|whence|unhash|ulimit|ttyctl|source|setopt|setcap|rehash|pushln|printf|noglob|getcap|enable|echoti|echotc|disown|zstat|zprof|zf_rm|zf_mv|zf_ln|which|where|vared|unset|umask|times|sched|rmdir|pushd|print|mkdir|limit|getln|false|clone|chown|chmod|chgrp|chdir|alias|ztie|ztcp|zpty|zftp|wait|type|true|trap|test|sync|stat|read|popd|kill|jobs|hash|exec|eval|echo|dirs|zle|pwd|mem|log|cap|bye|rm|mv|ln|fg|fc|cd|bg|r)\\b",
      "name": "support.function.builtin.zshrs"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.zshrs",
          "match": "\\|&?|&&|;;|;"
