      "name": "constant.numeric.zshrs"
    },
    "variables": {
      "patterns": [
        {
          "match": "\\$#?[A-Za-z_]\\w*",
          "name": "variable.other.zshrs"
        },
        {
          "match": "\\$\\{[^}]*\\}",
          "name": "variable.other.bracket.zshrs"
        },
        {
          "match": "\\$[0-9]",
          "name": "variable.language.positional.zshrs"
        },
        {
          "match": "\\$[@*#?$!-]",
          "name": "variable.language.special.zshrs"
        }
      ]
    },
